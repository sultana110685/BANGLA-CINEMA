<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bangla Cinema - Netflix Style</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:'Poppins',sans-serif;
    }

    body{
      background:#0b0b0b;
      color:#fff;
      overflow-x:hidden;
    }

    /* NAVBAR */
    header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:15px 30px;
      background:rgba(0,0,0,0.8);
      position:fixed;
      width:100%;
      top:0;
      z-index:1000;
      backdrop-filter: blur(10px);
    }

    .logo{
      font-size:24px;
      font-weight:700;
      color:red;
    }

    nav a{
      color:#fff;
      margin:0 12px;
      text-decoration:none;
      font-size:14px;
    }

    nav a:hover{
      color:red;
    }

    /* HERO */
    .hero{
      height:90vh;
      background:url('https://images.unsplash.com/photo-1524985069026-dd778a71c7b4?auto=format&fit=crop&w=1500&q=80') center/cover;
      display:flex;
      align-items:flex-end;
      padding:60px;
      position:relative;
    }

    .hero::after{
      content:'';
      position:absolute;
      top:0;
      left:0;
      width:100%;
      height:100%;
      background:linear-gradient(to top, #0b0b0b, transparent);
    }

    .hero-content{
      position:relative;
      z-index:2;
      max-width:600px;
    }

    .hero h1{
      font-size:50px;
      color:#fff;
      margin-bottom:10px;
    }

    .hero p{
      color:#ccc;
      margin-bottom:15px;
    }

    .btn{
      background:red;
      padding:10px 20px;
      border:none;
      color:#fff;
      margin-right:10px;
      cursor:pointer;
      border-radius:4px;
    }

    /* ROWS */
    .row{
      padding:20px 40px;
      margin-top:20px;
    }

    .row h2{
      margin-bottom:10px;
    }

    .row-posters{
      display:flex;
      overflow-x:auto;
      gap:10px;
      padding-bottom:10px;
    }

    .row-posters::-webkit-scrollbar{
      display:none;
    }

    .poster{
      min-width:160px;
      height:230px;
      background:#222;
      border-radius:6px;
      overflow:hidden;
      transition:transform 0.3s;
    }

    .poster:hover{
      transform:scale(1.1);
    }

    .poster img{
      width:100%;
      height:100%;
      object-fit:cover;
    }

    footer{
      text-align:center;
      padding:30px;
      color:#777;
      margin-top:40px;
    }

  </style>
</head>

<body>

<header>
  <div class="logo">🎬 BanglaFlix</div>
  <nav>
    <a href="#">Home</a>
    <a href="#movies">Movies</a>
    <a href="#actors">Actors</a>
  </nav>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <h1>Bangla Cinema Legends</h1>
    <p>Watch, Explore and Relive the Golden Era of Bangladeshi Film Industry</p>
    <button class="btn">Watch Now</button>
    <button class="btn">More Info</button>
  </div>
</section>

<!-- MOVIES -->
<section class="row" id="movies">
  <h2>🎥 Trending Movies</h2>
  <div class="row-posters">
    <div class="poster"><img src="https://via.placeholder.com/300x400"></div>
    <div class="poster"><img src="https://via.placeholder.com/300x400"></div>
    <div class="poster"><img src="https://via.placeholder.com/300x400"></div>
    <div class="poster"><img src="https://via.placeholder.com/300x400"></div>
  </div>
</section>

<!-- ACTORS -->
<section class="row" id="actors">
  <h2>🌟 Legendary Actors</h2>
  <div class="row-posters">
    <div class="poster"><img src="https://via.placeholder.com/300x400"></div>
    <div class="poster"><img src="https://via.placeholder.com/300x400"></div>
    <div class="poster"><img src="https://via.placeholder.com/300x400"></div>
  </div>
</section>

<!-- LEGENDS -->
<section class="row">
  <h2>🏆 Golden Era Legends</h2>
  <div class="row-posters">
    <div class="poster"><img src="https://via.placeholder.com/300x400"></div>
    <div class="poster"><img src="https://via.placeholder.com/300x400"></div>
    <div class="poster"><img src="https://via.placeholder.com/300x400"></div>
  </div>
</section>

<footer>
  © 2026 BanglaFlix | Inspired by Netflix UI
</footer>

</body>
</html>
